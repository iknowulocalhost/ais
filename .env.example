# ---- Среда ----
NODE_ENV=development

# ---- PostgreSQL (+TimescaleDB) ----
POSTGRES_USER=ais
POSTGRES_PASSWORD=ais_secret
POSTGRES_DB=ais_students
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_PASSWORD=redis_secret
REDIS_PORT=6379

# ---- MinIO ----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---- Backend ----
BACKEND_PORT=3001
JWT_ACCESS_SECRET=replace_with_strong_random_string
JWT_REFRESH_SECRET=replace_with_another_strong_random_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ---- SMTP (уведомления). Если SMTP_HOST не задан — пишем в консоль (dev). ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@chtotib.ru

# ---- Bootstrap ----
# Если заданы — при первом запуске создаётся SUPERADMIN.
SUPERADMIN_EMAIL=admin@chtotib.ru
SUPERADMIN_PASSWORD=ChangeMeOnFirstLogin!2026

# ---- Frontend ----
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# ---- Сетевой ПОО (poo.zabedu.ru, IRTech) ----
# Read-only интеграция. Один технический логин на школу. Хранить в секрет-менеджере в проде.
POOZABEDU_BASE_URL=https://poo.zabedu.ru
POOZABEDU_USERNAME=
POOZABEDU_PASSWORD=
POOZABEDU_TIMEOUT_MS=10000
POOZABEDU_MIN_INTERVAL_MS=500